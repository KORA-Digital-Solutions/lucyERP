// POC ERP Clínica Estética — Fase 1
// Agenda por cabinas + recordatorios WhatsApp.
//
// Nota: SQLite (vía Prisma) NO soporta `enum`. Los campos que en el spec
// son enums se modelan como `String` con un valor por defecto y se validan
// en la capa de aplicación (ver lib/enums.ts). El modelo incluye `clinicId`
// en todas las tablas para facilitar la evolución futura a multi-tenant.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Clinic {
  id                   String   @id @default(cuid())
  name                 String
  taxId                String?
  address              String?
  phone                String?
  email                String?
  timezone             String   @default("Europe/Madrid")
  openingTime          String   @default("09:00")
  closingTime          String   @default("20:00")
  whatsappEnabled      Boolean  @default(false)
  whatsappTemplateName String?  @default("appointment_reminder_es")
  whatsappTemplateLang String?  @default("es")
  reminderHoursBefore  Int      @default(24)
  inactivityWarningDays Int     @default(180)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  users        User[]
  cabins       Cabin[]
  customers    Customer[]
  services     Service[]
  appointments Appointment[]
  suppliers    Supplier[]
  products     Product[]
  sales        Sale[]
  cashRegisters CashRegister[]
}

// role: "ADMIN" | "WORKER"
model User {
  id                  String   @id @default(cuid())
  clinicId            String
  clinic              Clinic   @relation(fields: [clinicId], references: [id])
  name                String
  lastName            String?
  email               String?  @unique
  passwordHash        String?
  mustChangePassword  Boolean  @default(false)
  phone               String?
  role                String   @default("WORKER")
  active              Boolean  @default(true)
  color               String?  @default("#3C54A4")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  appointments         Appointment[]
  sales                Sale[]
  balanceMovements     CustomerBalanceMovement[]
  cashRegistersClosedBy CashRegister[]
}

model Cabin {
  id              String   @id @default(cuid())
  clinicId        String
  clinic          Clinic   @relation(fields: [clinicId], references: [id])
  name            String
  description     String?
  active          Boolean  @default(true)
  sortOrder       Int      @default(0)
  defaultWorkerId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  appointments Appointment[]
}

model Customer {
  id            String    @id @default(cuid())
  clinicId      String
  clinic        Clinic    @relation(fields: [clinicId], references: [id])
  firstName     String
  lastName      String?
  lastName2     String?
  phone         String
  phone2        String?
  email         String?
  birthDate     DateTime?
  notes         String?
  whatsappOptIn Boolean   @default(true)
  active        Boolean   @default(true)
  balanceCents  Int       @default(0) // Saldo a favor (crédito), siempre >= 0. La deuda vive en Sale.status = DEBT.
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  appointments     Appointment[]
  whatsappMessages WhatsappMessage[]
  sales            Sale[]
  balanceMovements CustomerBalanceMovement[]
}

// pricingType: "FIXED" | "PER_MINUTE"
model Service {
  id                  String   @id @default(cuid())
  clinicId            String
  clinic              Clinic   @relation(fields: [clinicId], references: [id])
  name                String
  description         String?
  durationMinutes     Int
  priceCents          Int
  pricingType         String   @default("FIXED")
  pricePerMinuteCents Int?
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  appointments Appointment[]
  saleLines    SaleLine[]
}

// status: PENDING | CONFIRMED | CANCELLED | DONE | NO_SHOW
// reminderStatus: NOT_SCHEDULED | PENDING | SENDING | SENT | FAILED | DELIVERED | READ
model Appointment {
  id                String    @id @default(cuid())
  clinicId          String
  clinic            Clinic    @relation(fields: [clinicId], references: [id])
  customerId        String
  customer          Customer  @relation(fields: [customerId], references: [id])
  serviceId         String
  service           Service   @relation(fields: [serviceId], references: [id])
  workerId          String
  worker            User      @relation(fields: [workerId], references: [id])
  cabinId           String
  cabin             Cabin     @relation(fields: [cabinId], references: [id])
  startAt           DateTime
  endAt             DateTime
  durationMinutes   Int
  status            String    @default("PENDING")
  reminderStatus    String    @default("NOT_SCHEDULED")
  notes             String?
  cancelledAt       DateTime?
  cancelledByUserId String?
  cancelReason      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  whatsappMessages WhatsappMessage[]

  @@index([clinicId, startAt])
  @@index([clinicId, cabinId, startAt])
  @@index([clinicId, workerId, startAt])
}

model Supplier {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  name      String
  phone     String?
  email     String?
  notes     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

// type: SALE | INTERNAL | BOTH (legacy, now unused — kept for future)
model Product {
  id          String    @id @default(cuid())
  clinicId    String
  clinic      Clinic    @relation(fields: [clinicId], references: [id])
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
  name        String
  description String?
  priceCents  Int       @default(0)
  costCents   Int       @default(0)
  stock       Int       @default(0)
  stockMin    Int       @default(0)
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  movements StockMovement[]
  saleLines SaleLine[]
}

// type: ENTRY | CONSUME | SALE
model StockMovement {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  userId    String
  type      String
  quantity  Int
  notes     String?
  saleId    String?
  createdAt DateTime @default(now())

  @@index([productId])
}

// saleType: "SALE" | "GIFT_CARD"
// status: "PAID" | "DEBT"
// paymentMethod: "CARD" | "CASH" | "BALANCE" | "DEBT"
model Sale {
  id            String   @id @default(cuid())
  clinicId      String
  clinic        Clinic   @relation(fields: [clinicId], references: [id])
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  saleType      String   @default("SALE")
  status        String   @default("PAID")
  paymentMethod String   @default("CASH")
  subtotalCents Int      @default(0)
  discountCents Int      @default(0)
  totalCents    Int      @default(0)
  paidCents     Int      @default(0)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lines            SaleLine[]
  balanceMovements CustomerBalanceMovement[]

  @@index([clinicId, createdAt])
  @@index([clinicId, customerId])
}

// type: "SERVICE" | "PRODUCT"
model SaleLine {
  id              String   @id @default(cuid())
  saleId          String
  sale            Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  type            String
  serviceId       String?
  service         Service?  @relation(fields: [serviceId], references: [id])
  productId       String?
  product         Product?  @relation(fields: [productId], references: [id])
  description     String
  quantity        Int      @default(1)
  unitPriceCents  Int
  discountPercent Int      @default(0)
  durationMinutes Int?
  totalCents      Int

  @@index([saleId])
}

// type: "GIFT_CARD_IN" | "BALANCE_USED"  (DEBT_CREATED/DEBT_PAID: legacy, ya no se generan)
model CustomerBalanceMovement {
  id          String   @id @default(cuid())
  clinicId    String
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String
  amountCents Int
  saleId      String?
  sale        Sale?    @relation(fields: [saleId], references: [id])
  notes       String?
  createdAt   DateTime @default(now())

  @@index([customerId])
}

// status: "OPEN" | "CLOSED"
model CashRegister {
  id                  String    @id @default(cuid())
  clinicId            String
  clinic              Clinic    @relation(fields: [clinicId], references: [id])
  date                String
  status              String    @default("OPEN")
  openingCashCents    Int       @default(0)
  totalCardCents      Int       @default(0)
  totalCashCents      Int       @default(0)
  closingDeclaredCents Int?
  closingKeptCents    Int?
  differenceCents     Int?
  denominationNotes   String?
  closedByUserId      String?
  closedBy            User?     @relation(fields: [closedByUserId], references: [id])
  closedAt            DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([clinicId, date])
  @@index([clinicId, date])
}

// direction: OUTBOUND | INBOUND
// status: PENDING | SENT | FAILED | DELIVERED | READ | RECEIVED
model WhatsappMessage {
  id                String       @id @default(cuid())
  clinicId          String
  appointmentId     String?
  appointment       Appointment? @relation(fields: [appointmentId], references: [id])
  customerId        String?
  customer          Customer?    @relation(fields: [customerId], references: [id])
  direction         String
  toPhone           String?
  fromPhone         String?
  templateName      String?
  templateLanguage  String?
  providerMessageId String?
  status            String       @default("PENDING")
  payloadJson       String?
  responseJson      String?
  errorCode         String?
  errorMessage      String?
  sentAt            DateTime?
  receivedAt        DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([clinicId, appointmentId])
  @@index([providerMessageId])
}
